# Nina v2 — host deploy environment
# Installed under /opt/nina by:
#   curl -fsSL https://motirolabs.com/nina/install.sh | bash
# Edit as .env, then: nina up
#
# Secrets stay here and under NINA_DATA_ROOT. Never bake into images.

# =============================================================================
# 1. Images (Docker Hub)
# =============================================================================
# → carlosrabelo/nina-telegram:latest
NINA_IMAGE_PREFIX=carlosrabelo/nina
NINA_IMAGE_TAG=latest
# NINA_PULL=always

# =============================================================================
# 2. Host data root (bind mounts)
# =============================================================================
#   $NINA_DATA_ROOT/postgres
#   $NINA_DATA_ROOT/nats
#   $NINA_DATA_ROOT/google/tokens
#   $NINA_DATA_ROOT/google/credentials
NINA_DATA_ROOT=/opt/ninabot

# =============================================================================
# 3. Runtime
# =============================================================================
NINA_HTTP_HOST=0.0.0.0
NINA_HTTP_PORT=8080
NINA_LOG_LEVEL=INFO
NINA_DEFAULT_LOCALE=pt
# TZ=Etc/GMT+4
# PGTZ=Etc/GMT+4

# =============================================================================
# 4. NATS (JetStream)
# =============================================================================
NATS_URL=nats://nats:4222
# NATS_PORT=4222
# NATS_MONITOR_PORT=8222

# =============================================================================
# 5. PostgreSQL
# =============================================================================
POSTGRES_USER=nina
POSTGRES_PASSWORD=nina
POSTGRES_DB=nina
DATABASE_URL=postgresql://nina:nina@postgres:5432/nina

# =============================================================================
# 6. Telegram
# =============================================================================
# Deny-by-default: channel:user_id[,…]
NINA_OWNER_ALLOWLIST=
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=

# =============================================================================
# 7. Core — LLM (when core is on the host stack)
# =============================================================================
LLM_MODEL=
GROQ_API_KEY=

# =============================================================================
# 8. Skills (when skills is on the host stack)
# =============================================================================
NINA_SKILLS_ENABLED=

# =============================================================================
# 9. Google OAuth mounts
# =============================================================================
TOKENS_DIR=/google/tokens
GOOGLE_CREDENTIALS_FILE=/google/credentials/credentials.json
GOOGLE_CREDENTIALS_MOUNT_DIR=/google/credentials
